package com.analyser.controller;

import com.analyser.model.ResumeInfo;
import com.analyser.service.ResumeService;
import org.apache.tika.metadata.Metadata;
import org.apache.tika.parser.AutoDetectParser;
import org.apache.tika.sax.BodyContentHandler;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.web.bind.annotation.*;
import org.springframework.web.multipart.MultipartFile;

import java.io.InputStream;
import java.util.List;
import java.util.regex.Matcher;
import java.util.regex.Pattern;
import java.util.stream.Collectors;

@RestController
@RequestMapping("/api/resume")
public class ResumeController {

    @Autowired
    private ResumeService resumeService;

    @PostMapping("/save")
    public ResumeInfo saveResume(@RequestBody ResumeInfo info) {
        return resumeService.saveResume(info);
    }

    @PostMapping("/upload")
    public ResumeInfo uploadResume(@RequestParam("file") MultipartFile file) {
        String content = extractText(file);

        ResumeInfo info = new ResumeInfo();
        info.setName(extractName(content));
        info.setEmail(extractEmail(content));
        info.setPhone(extractPhone(content));
        info.setSkills(extractSkills(content));
        info.setExperience("Auto-detected"); // You can add logic later
        info.setEducation("Auto-detected"); // You can add logic later
        info.setRawText(content);

        return resumeService.saveResume(info);
    }

    private String extractText(MultipartFile file) {
        try (InputStream stream = file.getInputStream()) {
            AutoDetectParser parser = new AutoDetectParser();
            BodyContentHandler handler = new BodyContentHandler(-1); // No size limit
            Metadata metadata = new Metadata();
            parser.parse(stream, handler, metadata);
            return handler.toString();
        } catch (Exception e) {
            throw new RuntimeException("Failed to parse resume", e);
        }
    }

    private String extractEmail(String text) {
        Pattern pattern = Pattern.compile("[a-zA-Z0-9._%+-]+@[a-zA-Z0-9.-]+\\.[a-z]{2,}");
        Matcher matcher = pattern.matcher(text);
        return matcher.find() ? matcher.group() : "unknown@example.com";
    }

    private String extractPhone(String text) {
        Pattern pattern = Pattern.compile("\\d{10}");
        Matcher matcher = pattern.matcher(text);
        return matcher.find() ? matcher.group() : "0000000000";
    }

    private String extractName(String text) {
        return text.split("\n")[0].trim(); // First line assumed as name
    }

    private String extractSkills(String text) {
        List<String> keywords = List.of("Java", "Spring", "SQL", "Python", "AWS");
        return keywords.stream()
                .filter(text::contains)
                .collect(Collectors.joining(", "));
    }
}
